# DATABASE_URL=postgresql://naijamed_user:naijamed_password@postgres:5432/naijamed_db

# Option 2: Use External Render PostgreSQL (for production)
DATABASE_URL=postgresql://naijamed_database_user:GKxnanDr2F6DNdYfbVbMXFUmqFM4u9pQ@dpg-d8k2qu58nd3s73cectlg-a.frankfurt-postgres.render.com/naijamed_database

