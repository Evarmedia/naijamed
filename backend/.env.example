# ========== Environment Configuration ==========

# Application Port
PORT=3055

# Node Environment (development, staging, production)
NODE_ENV=development

# ========== Database Configuration ==========

# Option 1: Use Local PostgreSQL (for Docker development)
# DATABASE_URL=postgresql://naijamed_user:naijamed_password@postgres:5432/naijamed_db

# Option 2: Use External Render PostgreSQL (for production)
DATABASE_URL=xxxxxx

# Option 3: Leave DATABASE_URL empty to use SQLite (local development without Docker)
# DATABASE_URL=

# ========== JWT Configuration ==========
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=xx

# ========== Email Configuration ==========
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@naijamed.com

# ========== Frontend Configuration ==========
FRONTEND_URL=http://localhost:8000

# ========== AI Service Configuration ==========
AI_SERVICE_URL=xxxxxx/api/v1/chat/
GROQ_API_KEY=your-groq-api-key

# ========== Redis Configuration (optional) ==========
REDIS_URL=redis://localhost:xxxx

# ========== CORS Configuration ==========
CORS_ORIGIN=http://localhost:xxxx,http://localhost:xxxx
